# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Obtén esto en: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/dripbatch?retryWrites=true&w=majority

# ── Cloudinary ─────────────────────────────────────────────────────────────────
# Obtén esto en: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Acceso ─────────────────────────────────────────────────────────────────────
# Contraseña compartida para entrar a la app. Si se deja vacía, no pide login.
APP_PASSWORD=

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3001
